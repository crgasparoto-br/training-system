// ============================================================================
// BIBLIOTECA DE EXERCÃCIOS
// ============================================================================

model ExerciseLibrary {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  name         String // Nome do exercÃ­cio
  videoUrl     String?       @db.Text // Link do vÃ­deo do YouTube
  loadType     LoadType? // H, C, E, A, P, O
  movementType MovementType? // U, I, O
  countingType CountingType? // I, T, R
  category     String? // MOBILIDADE, RESISTIDO, CICLICO
  muscleGroup  String? // Abdominal, QuadrÃ­ceps, etc
  notes        String?       @db.Text

  // Relacionamentos
  workoutExercises WorkoutExercise[]
  alunoProgress    AlunoExerciseProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([contractId, name])
  @@index([contractId, category])
}

enum LoadType {
  H // Halteres
  C // Corporal
  E // ElÃ¡sticos
  A // AerÃ³bicos
  P // P.S. (observaÃ§Ãµes)
  O // Outros
}

enum MovementType {
  U // Unilateral
  I // Isolado
  O // Outros (Bilateral)
}

enum CountingType {
  I // Isometria
  T // por Tempo (RepetiÃ§Ãµes)
  R // RepetiÃ§Ãµes
}

// ============================================================================
// PROGRESSO DO ALUNO POR EXERCÃCIO
// ============================================================================

model AlunoExerciseProgress {
  id         String          @id @default(cuid())
  alunoId    String
  aluno      Aluno           @relation(fields: [alunoId], references: [id], onDelete: Cascade)
