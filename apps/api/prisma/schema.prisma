// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTENTICAÃ‡ÃƒO E USUÃRIOS
// ============================================================================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  type         UserType
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  profile      Profile?

  // Relacionamentos
  professor               Professor?
  aluno                   Aluno?
  notifications           Notification[]
  notificationPreferences NotificationPreferences?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

enum UserType {
  professor
  aluno
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  avatar    String?
  phone     String?
  birthDate DateTime?
  gender    Gender?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Gender {
  male
  female
  other
}

// ============================================================================
// CONTRATOS
// ============================================================================

model Contract {
  id       String       @id @default(cuid())
  type     ContractType
  document String       @unique
  name     String?

  professores          Professor[]
  collaboratorFunctions CollaboratorFunctionOption[]
  trainingParameters   TrainingParameter[]
  exerciseLibrary      ExerciseLibrary[]
  assessmentTypes      AssessmentType[]
  subjectiveScaleItems SubjectiveScaleItem[]
  trainingSpaces       TrainingSpace[]
  agendaBookings       AgendaBooking[]
  cloneLogsAsSource    ContractDataCloneLog[] @relation("ContractCloneSource")
  cloneLogsAsTarget    ContractDataCloneLog[] @relation("ContractCloneTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

enum ContractType {
  academy
  personal
}

// ============================================================================
// PROFESSORES
// ============================================================================

enum ProfessorRole {
  master
  professor
}

model CollaboratorFunctionOption {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  name     String
  code     String
  isActive Boolean @default(true)
  isSystem Boolean @default(false)

  professores Professor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, code])
  @@index([contractId])
}

model Professor {
  id         String        @id @default(cuid())
  userId     String        @unique
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractId String
  contract   Contract      @relation(fields: [contractId], references: [id], onDelete: Cascade)
  role       ProfessorRole @default(professor)
  collaboratorFunctionId String
  collaboratorFunction CollaboratorFunctionOption @relation(fields: [collaboratorFunctionId], references: [id], onDelete: Restrict)
  responsibleManagerId String?
  responsibleManager   Professor? @relation("ProfessorResponsibleManager", fields: [responsibleManagerId], references: [id], onDelete: SetNull)

  // Relacionamentos
  managedCollaborators Professor[] @relation("ProfessorResponsibleManager")
  alunos              Aluno[]
  plans               TrainingPlan[]
  library             TrainingLibrary[]
  subscription        Subscription?
  cloneLogs           ContractDataCloneLog[]
  assessmentAuditLogs AssessmentAuditLog[]
  availabilities      ProfessorAvailability[]
  fixedSlots          FixedScheduleSlot[]
  agendaBookings      AgendaBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([collaboratorFunctionId])
  @@index([responsibleManagerId])
}

model ContractDataCloneLog {
  id               String     @id @default(cuid())
  sourceContractId String
  sourceContract   Contract   @relation("ContractCloneSource", fields: [sourceContractId], references: [id], onDelete: Cascade)
  targetContractId String
  targetContract   Contract   @relation("ContractCloneTarget", fields: [targetContractId], references: [id], onDelete: Cascade)
  professorId      String?
  professor        Professor? @relation(fields: [professorId], references: [id], onDelete: SetNull)

  parametersCreated      Int
  parametersSkipped      Int
  exercisesCreated       Int
  exercisesSkipped       Int
  assessmentTypesCreated Int @default(0)
  assessmentTypesSkipped Int @default(0)

  createdAt DateTime @default(now())

  @@index([sourceContractId])
  @@index([targetContractId])
  @@index([professorId])
}

// ============================================================================
// ALUNOS
// ============================================================================

model Aluno {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)

  // Dados AntropomÃ©tricos
  age               Int
  weight            Float // kg
  height            Float // cm
  bodyFatPercentage Float? // %

  // Performance
  vo2Max             Float // ml/kg/min
  anaerobicThreshold Float // km/h
  maxHeartRate       Int // bpm
  restingHeartRate   Int // bpm
  systolicPressure   Int?
  diastolicPressure  Int?
  schedulePlan       AlunoSchedulePlan @default(free)

  // Relacionamentos
  trainingPlans     TrainingPlan[]
  executions        TrainingExecution[]
  progressMetrics   ProgressMetric[]
  macronutrients    Macronutrients?
  intakeForm        AlunoIntakeForm?
  integrations      Integration[]
  nutritionPlans    NutritionPlan[]
  exerciseProgress  AlunoExerciseProgress[]
  workoutExecutions WorkoutExecution[]
  assessments       Assessment[]
  fixedSlots        FixedScheduleSlot[]
  agendaBookings    AgendaBooking[]

  lastPasswordResetAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([professorId])
}

enum AlunoSchedulePlan {
  free
  fixed
}

model AlunoIntakeForm {
  id      String @id @default(cuid())
  alunoId String @unique
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  assessmentDate     DateTime?
  mainGoal           String? @db.Text
  medicalHistory     String? @db.Text
  currentMedications String? @db.Text
  injuriesHistory    String? @db.Text
  trainingBackground String? @db.Text
  observations       String? @db.Text
  parqResponses      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assessmentDate])
}

// ============================================================================
// AGENDA E DISPONIBILIDADES
// ============================================================================

model TrainingSpace {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  name     String
  capacity Int     @default(1)
  isActive Boolean @default(true)

  fixedSlots FixedScheduleSlot[]
  bookings   AgendaBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, name])
  @@index([contractId])
}

model ProfessorAvailability {
  id          String    @id @default(cuid())
  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)

  dayOfWeek Int // 1=Segunda, 7=Domingo
  startTime String // HH:mm
  endTime   String // HH:mm
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([professorId, dayOfWeek, startTime, endTime])
  @@index([professorId, dayOfWeek])
}

model FixedScheduleSlot {
  id          String         @id @default(cuid())
  alunoId     String
  aluno       Aluno          @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  professorId String
  professor   Professor      @relation(fields: [professorId], references: [id], onDelete: Cascade)
  spaceId     String?
  space       TrainingSpace? @relation(fields: [spaceId], references: [id], onDelete: SetNull)

  dayOfWeek Int // 1=Segunda, 7=Domingo
  startTime String // HH:mm
  endTime   String // HH:mm
  isActive  Boolean @default(true)
  notes     String? @db.Text

  bookings AgendaBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([alunoId, isActive])
  @@index([professorId, dayOfWeek, isActive])
  @@index([spaceId, dayOfWeek, isActive])
}

enum AgendaBookingType {
  free
  fixed_makeup
}

enum AgendaBookingStatus {
  scheduled
  completed
  canceled
  no_show
}

model AgendaBooking {
  id          String             @id @default(cuid())
  contractId  String
  contract    Contract           @relation(fields: [contractId], references: [id], onDelete: Cascade)
  alunoId     String
  aluno       Aluno              @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  professorId String
  professor   Professor          @relation(fields: [professorId], references: [id], onDelete: Cascade)
  spaceId     String?
  space       TrainingSpace?     @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  fixedSlotId String?
  fixedSlot   FixedScheduleSlot? @relation(fields: [fixedSlotId], references: [id], onDelete: SetNull)

  bookingType    AgendaBookingType
  status         AgendaBookingStatus @default(scheduled)
  bookingDate    DateTime
  startTime      String // HH:mm
  endTime        String // HH:mm
  notes          String?             @db.Text
  canceledReason String?             @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId, bookingDate])
  @@index([alunoId, bookingDate])
  @@index([professorId, bookingDate])
  @@index([spaceId, bookingDate])
  @@index([fixedSlotId])
}

// ============================================================================
// AVALIACOES FISICAS
// ============================================================================

enum AssessmentScheduleType {
  fixed_interval
  after_type
}

enum SubjectiveScaleType {
  PSE
  PSR
}

enum AssessmentAuditAction {
  update
  delete
}

model AssessmentType {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  name           String
  code           String
  description    String?
  scheduleType   AssessmentScheduleType
  intervalMonths Int?
  afterTypeId    String?
  afterType      AssessmentType?        @relation("AssessmentTypeDependencies", fields: [afterTypeId], references: [id], onDelete: SetNull)
  offsetMonths   Int?
  isActive       Boolean                @default(true)

  assessments Assessment[]
  dependents  AssessmentType[] @relation("AssessmentTypeDependencies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, code])
  @@index([contractId])
}

model Assessment {
  id      String         @id @default(cuid())
  alunoId String
  aluno   Aluno          @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  typeId  String
  type    AssessmentType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  assessmentDate DateTime

  filePath         String
  originalFileName String
  mimeType         String
  fileSize         Int
  extractedData    Json?
  auditLogs        AssessmentAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([alunoId])
  @@index([typeId])
  @@index([assessmentDate])
}

model AssessmentAuditLog {
  id           String                @id @default(cuid())
  assessmentId String
  assessment   Assessment            @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  professorId  String
  professor    Professor             @relation(fields: [professorId], references: [id], onDelete: Cascade)
  action       AssessmentAuditAction
  beforeData   Json?
  afterData    Json?
  createdAt    DateTime              @default(now())

  @@index([assessmentId])
  @@index([professorId])
}

// ============================================================================
// PLANOS DE TREINO
// ============================================================================

model TrainingPlan {
  id          String    @id @default(cuid())
  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  alunoId     String
  aluno       Aluno     @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  name        String
  description String?
  startDate   DateTime
  endDate     DateTime

  macrocycles      Macrocycle[]
  periodization    PeriodizationMatrix?
  workoutTemplates WorkoutTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([professorId])
  @@index([alunoId])
}

model Macrocycle {
  id     String       @id @default(cuid())
  planId String
  plan   TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  name       String
  phase      TrainingPhase
  weekStart  Int
  weekEnd    Int
  focusAreas String[] // JSON array

  mesocycles Mesocycle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
}

enum TrainingPhase {
  base
  build
  peak
  recovery
  taper
}

model Mesocycle {
  id           String     @id @default(cuid())
  macrocycleId String
  macrocycle   Macrocycle @relation(fields: [macrocycleId], references: [id], onDelete: Cascade)

  weekNumber   Int
  startDate    DateTime
  endDate      DateTime
  focus        String?
  volumeTarget Float? // km

  microcycles Microcycle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([macrocycleId])
}

model Microcycle {
  id          String    @id @default(cuid())
  mesocycleId String
  mesocycle   Mesocycle @relation(fields: [mesocycleId], references: [id], onDelete: Cascade)

  dayOfWeek   Int // 0-6 (segunda a domingo)
  sessionType SessionType

  // Planejamento
  durationMinutes     Int
  distanceKm          Float?
  intensityPercentage Float // 50-100%
  paceMinPerKm        Float? // minutos por km
  heartRateZone       Int? // 1-5

  // InstruÃ§Ãµes
  instructions String?
  notes        String?

  // Relacionamentos
  executions TrainingExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mesocycleId])
}

enum SessionType {
  easy
  moderate
  threshold
  vo2max
  anaerobic
  recovery
  long_run
  strength
  cross_training
}

// ============================================================================
// EXECUÃ‡ÃƒO DE TREINOS
// ============================================================================

model TrainingExecution {
  id           String     @id @default(cuid())
  microcycleId String
  microcycle   Microcycle @relation(fields: [microcycleId], references: [id], onDelete: Cascade)
  alunoId      String
  aluno        Aluno      @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  plannedDate  DateTime
  executedDate DateTime?
  completed    Boolean   @default(false)

  // Dados Executados
  durationActual Int? // minutos
  distanceActual Float? // km
  heartRateAvg   Int? // bpm
  heartRateMax   Int? // bpm
  pace           Float? // min/km

  // PercepÃ§Ãµes
  pse Int? // Perceived Exertion Scale (1-10)
  psr Int? // Perceived Recovery Scale (1-10)

  // Notas
  notes String?

  // IntegraÃ§Ãµes
  garminActivityId String?
  stravaActivityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([microcycleId])
  @@index([alunoId])
}

// ============================================================================
// NUTRIÃ‡ÃƒO
// ============================================================================

model Macronutrients {
  id      String @id @default(cuid())
  alunoId String @unique
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  carbohydratesPercentage Float // 56.8%
  proteinsPercentage      Float // 25.6%
  lipidsPercentage        Float // 17.6%

  dailyCalories Int?

  updatedAt DateTime @updatedAt
}

model NutritionPlan {
  id      String @id @default(cuid())
  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  plan        Json // Plano estruturado
  source      String // dieta_ia, manual, etc
  rawResponse String? // Resposta bruta

  validFrom  DateTime
  validUntil DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([alunoId])
}

// ============================================================================
// PROGRESSO
// ============================================================================

model ProgressMetric {
  id      String @id @default(cuid())
  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  date              DateTime
  weight            Float? // kg
  bodyFatPercentage Float? // %
  vo2MaxEstimated   Float? // ml/kg/min
  notes             String?

  createdAt DateTime @default(now())

  @@index([alunoId])
}

// ============================================================================
// BIBLIOTECA DE TREINOS
// ============================================================================

model TrainingLibrary {
  id          String    @id @default(cuid())
  professorId String
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)

  name                String
  description         String?
  sessionType         SessionType
  durationMinutes     Int
  intensityPercentage Float
  instructions        String?

  isTemplate Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([professorId])
}

// ============================================================================
// INTEGRAÃ‡Ã•ES
// ============================================================================

model Integration {
  id      String @id @default(cuid())
  alunoId String
  aluno   Aluno  @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  type         IntegrationType
  accessToken  String? // Criptografado
  refreshToken String? // Criptografado
  expiresAt    DateTime?

  lastSync DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([alunoId, type])
  @@index([alunoId])
}

enum IntegrationType {
  garmin
  strava
  apple_health
  dieta_ia
}

// ============================================================================
// PAGAMENTOS
// ============================================================================

model Subscription {
  id          String    @id @default(cuid())
  professorId String    @unique
  professor   Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)

  plan   Plan
  status String // active, canceled, past_due

  stripeCustomerId String?
  stripeSubId      String? @unique

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  canceledAt   DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Plan {
  free
  pro
  enterprise
}

model Payment {
  id          String @id @default(cuid())
  professorId String

  stripeId String @unique
  amount   Float
  currency String // BRL
  status   String // pending, succeeded, failed

  createdAt DateTime @default(now())

  @@index([professorId])
}

// ============================================================================
// NOTIFICAÃ‡Ã•ES
// ============================================================================

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String
  data    Json?

  emailSent    Boolean @default(false)
  smsSent      Boolean @default(false)
  whatsappSent Boolean @default(false)

  emailError    String?
  smsError      String?
  whatsappError String?

  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([userId])
}

enum NotificationType {
  new_aluno
  training_completed
  training_missed
  payment_received
  plan_expiring
  new_training
  training_reminder
  professor_feedback
  progress_achieved
}

model NotificationPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailEnabled    Boolean @default(true)
  smsEnabled      Boolean @default(true)
  whatsappEnabled Boolean @default(true)

  emailFrequency    String // immediate, daily, weekly
  smsFrequency      String // immediate, daily
  whatsappFrequency String // immediate, daily

  updatedAt DateTime @updatedAt
}

// ============================================================================
// PERIODIZAÃ‡ÃƒO MACROCICLO
// ============================================================================

// Tabela de ParÃ¢metros ConfigurÃ¡veis
model TrainingParameter {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  category    String // "montagem", "metodo", "divisao_treino", "carga_microciclo", "objetivo"
  code        String // "AS", "SER", "FB", "ADP", etc
  description String // DescriÃ§Ã£o completa
  order       Int // Ordem de exibiÃ§Ã£o
  active      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, category, code])
  @@index([contractId, category])
}

model SubjectiveScaleItem {
  id         String              @id @default(cuid())
  contractId String
  contract   Contract            @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type       SubjectiveScaleType
  value      Int
  label      String?
  order      Int
  isActive   Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contractId, type, value])
  @@index([contractId, type])
}

// Matriz de PeriodizaÃ§Ã£o
model PeriodizationMatrix {
  id     String       @id @default(cuid())
  planId String       @unique
  plan   TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  totalMesocycles   Int // Ex: 5
  weeksPerMesocycle Int // Ex: 4

  // Relacionamentos
  resistedStimulus ResistedStimulus[]
  cyclicStimulus   CyclicStimulus[]
  nutrition        NutritionWeekly[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// EstÃ­mulo Resistido (Treino de ForÃ§a)
model ResistedStimulus {
  id       String              @id @default(cuid())
  matrixId String
  matrix   PeriodizationMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)

  mesocycleNumber Int // 1, 2, 3, 4, 5
  weekNumber      Int // 1-20 (ou quantas semanas tiver)

  // Carga Microciclo (ADP, ORD, CHO, REG)
  loadCycle String? // ReferÃªncia ao TrainingParameter

  // Objetivo
  objective String? // ReferÃªncia ao TrainingParameter

  // ParÃ¢metros de Treino Resistido
  repZone        Int? // Zona de RepetiÃ§Ãµes (ex: 4, 6, 8, 10, 12, 14)
  loadPercentage Float? // % Carga TR (calculado automaticamente baseado em repZone)

  // ReferÃªncia para cÃ¡lculo de sÃ©ries
  seriesReference Int? // REF - valor de referÃªncia

  // SÃ©ries calculadas
  seriesLowerBody Int? // SÃ©ries Membros Inferiores (calculado)
  seriesUpperBody Int? // SÃ©ries Membros Superiores
  seriesCore      Int? // SÃ©ries Core/EstabilizaÃ§Ã£o

  // Rep Reserva (calculado automaticamente)
  repReserve Int? // Calculado baseado em loadCycle

  // Montagem (AS, A/AN, CA, CGM, MIS)
  assembly String? // ReferÃªncia ao TrainingParameter

  // MÃ©todo (SER, BS, TS, SS, CIR, CS, PC, PD, DS, RP, SN, FST-7)
  method String? // ReferÃªncia ao TrainingParameter

  // DivisÃ£o do Treino (FB, AB, ABC, ABCD, ABCDE)
  trainingDivision String? // ReferÃªncia ao TrainingParameter

  // FrequÃªncia Semanal
  weeklyFrequency Int? // Ex: 3, 4, 5

  // ObservaÃ§Ãµes
  observations String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matrixId, mesocycleNumber, weekNumber])
  @@index([matrixId])
}

// EstÃ­mulo CÃ­clico (Corrida/Cardio)
model CyclicStimulus {
  id       String              @id @default(cuid())
  matrixId String
  matrix   PeriodizationMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)

  mesocycleNumber Int
  weekNumber      Int

  // Volume
  totalVolumeMinutes Float? // Volume Geral em Minutos
  totalVolumeKm      Float? // Volume Geral em KM
  runningVolumeKm    Float? // Volume Corrida em KM

  // NÃºmero de Treinos por Zona
  countZ1 Int? // NÃºmero de treinos Zona 1
  countZ2 Int?
  countZ3 Int?
  countZ4 Int?
  countZ5 Int?

  // Minutos por Zona
  minutesZ1 Float? // Minutos na Zona 1
  minutesZ2 Float?
  minutesZ3 Float?
  minutesZ4 Float?
  minutesZ5 Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matrixId, mesocycleNumber, weekNumber])
  @@index([matrixId])
}

// NutriÃ§Ã£o Semanal
model NutritionWeekly {
  id       String              @id @default(cuid())
  matrixId String
  matrix   PeriodizationMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)

  mesocycleNumber Int
  weekNumber      Int

  // Calorias e Macronutrientes
  dailyCalories  Float? // Calorias diÃ¡rias
  carbohydratesG Float? // Carboidratos em gramas
  proteinsG      Float? // ProteÃ­nas em gramas
  lipidsG        Float? // LipÃ­dios em gramas

  // HidrataÃ§Ã£o
  hydrationLiters Float? // HidrataÃ§Ã£o em litros/dia

  // Suplementos
  supplements String? @db.Text

  // ObservaÃ§Ãµes
  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matrixId, mesocycleNumber, weekNumber])
  @@index([matrixId])
}

// ============================================================================
// TEMPLATES DE PERIODIZAÃ‡ÃƒO
// ============================================================================

model PeriodizationTemplate {
  id          String  @id @default(cuid())
  professorId String? // null = template global

  name        String // "PreparaÃ§Ã£o para Maratona", "Base AerÃ³bica"
  description String? @db.Text
  category    String // "marathon", "base", "peak", etc

  totalMesocycles   Int
