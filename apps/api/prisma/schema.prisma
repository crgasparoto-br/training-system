  // Dados Executados
  setsCompleted Int?
  repsCompleted Int?
  loadUsed      Float?

  // Feedback
  difficultyRating Int? // 1-10
  repsInReserve    Int? // RepetiÃ§Ãµes em reserva
  notes            String? @db.Text

  createdAt DateTime @default(now())

  @@index([workoutExerciseId])
  @@index([alunoId])
  @@index([executionDate])
}
