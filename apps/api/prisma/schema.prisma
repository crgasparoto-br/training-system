// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTENTICAÇÃO E USUÁRIOS
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  type          UserType
  profile       Profile?
  
  // Relacionamentos
  educator      Educator?
  athlete       Athlete?
  notifications Notification[]
  notificationPreferences NotificationPreferences?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

enum UserType {
  educator
  student
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name      String
  avatar    String?
  phone     String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// EDUCADORES
// ============================================================================

model Educator {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relacionamentos
  athletes    Athlete[]
  plans       TrainingPlan[]
  library     TrainingLibrary[]
  subscription Subscription?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================================================
// ATLETAS
// ============================================================================

model Athlete {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  educatorId              String
  educator                Educator  @relation(fields: [educatorId], references: [id], onDelete: Cascade)
  
  // Dados Antropométricos
  age                     Int
  weight                  Float     // kg
  height                  Float     // cm
  bodyFatPercentage       Float?    // %
  
  // Performance
  vo2Max                  Float     // ml/kg/min
  anaerobicThreshold      Float     // km/h
  maxHeartRate            Int       // bpm
  restingHeartRate        Int       // bpm
  
  // Relacionamentos
  trainingPlans           TrainingPlan[]
  executions              TrainingExecution[]
  progressMetrics         ProgressMetric[]
  macronutrients          Macronutrients?
  integrations            Integration[]
  nutritionPlans          NutritionPlan[]
  exerciseProgress        StudentExerciseProgress[]
  workoutExecutions       WorkoutExecution[]
  
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([educatorId])
}

// ============================================================================
// PLANOS DE TREINO
// ============================================================================

model TrainingPlan {
  id              String    @id @default(cuid())
  educatorId      String
  educator        Educator  @relation(fields: [educatorId], references: [id], onDelete: Cascade)
  athleteId       String
  athlete         Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  startDate       DateTime
  endDate         DateTime
  
  macrocycles     Macrocycle[]
  periodization   PeriodizationMatrix?
  workoutTemplates WorkoutTemplate[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([educatorId])
  @@index([athleteId])
}

model Macrocycle {
  id              String    @id @default(cuid())
  planId          String
  plan            TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  name            String
  phase           TrainingPhase
  weekStart       Int
  weekEnd         Int
  focusAreas      String[]  // JSON array
  
  mesocycles      Mesocycle[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([planId])
}

enum TrainingPhase {
  base
  build
  peak
  recovery
  taper
}

model Mesocycle {
  id              String    @id @default(cuid())
  macrocycleId    String
  macrocycle      Macrocycle @relation(fields: [macrocycleId], references: [id], onDelete: Cascade)
  
  weekNumber      Int
  startDate       DateTime
  endDate         DateTime
  focus           String?
  volumeTarget    Float?    // km
  
  microcycles     Microcycle[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([macrocycleId])
}

model Microcycle {
  id                  String    @id @default(cuid())
  mesocycleId         String
  mesocycle           Mesocycle @relation(fields: [mesocycleId], references: [id], onDelete: Cascade)
  
  dayOfWeek           Int       // 0-6 (segunda a domingo)
  sessionType         SessionType
  
  // Planejamento
  durationMinutes     Int
  distanceKm          Float?
  intensityPercentage Float     // 50-100%
  paceMinPerKm        Float?    // minutos por km
  heartRateZone       Int?      // 1-5
  
  // Instruções
  instructions        String?
  notes               String?
  
  // Relacionamentos
  executions          TrainingExecution[]
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([mesocycleId])
}

enum SessionType {
  easy
  moderate
  threshold
  vo2max
  anaerobic
  recovery
  long_run
  strength
  cross_training
}

// ============================================================================
// EXECUÇÃO DE TREINOS
// ============================================================================

model TrainingExecution {
  id                  String    @id @default(cuid())
  microcycleId        String
  microcycle          Microcycle @relation(fields: [microcycleId], references: [id], onDelete: Cascade)
  athleteId           String
  athlete             Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  
  plannedDate         DateTime
  executedDate        DateTime?
  completed           Boolean   @default(false)
  
  // Dados Executados
  durationActual      Int?      // minutos
  distanceActual      Float?    // km
  heartRateAvg        Int?      // bpm
  heartRateMax        Int?      // bpm
  pace                Float?    // min/km
  
  // Percepções
  pse                 Int?      // Perceived Exertion Scale (1-10)
  psr                 Int?      // Perceived Recovery Scale (1-10)
  
  // Notas
  notes               String?
  
  // Integrações
  garminActivityId    String?
  stravaActivityId    String?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([microcycleId])
  @@index([athleteId])
}

// ============================================================================
// NUTRIÇÃO
// ============================================================================

model Macronutrients {
  id                      String    @id @default(cuid())
  athleteId               String    @unique
  athlete                 Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  
  carbohydratesPercentage Float     // 56.8%
  proteinsPercentage      Float     // 25.6%
  lipidsPercentage        Float     // 17.6%
  
  dailyCalories           Int?
  
  updatedAt               DateTime  @updatedAt
}

model NutritionPlan {
  id              String    @id @default(cuid())
  athleteId       String
  athlete         Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  
  plan            Json      // Plano estruturado
  source          String    // dieta_ia, manual, etc
  rawResponse     String?   // Resposta bruta
  
  validFrom       DateTime
  validUntil      DateTime
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([athleteId])
}

// ============================================================================
// PROGRESSO
// ============================================================================

model ProgressMetric {
  id                  String    @id @default(cuid())
  athleteId           String
  athlete             Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  
  date                DateTime
  weight              Float?    // kg
  bodyFatPercentage   Float?    // %
  vo2MaxEstimated     Float?    // ml/kg/min
  notes               String?
  
  createdAt           DateTime  @default(now())

  @@index([athleteId])
}

// ============================================================================
// BIBLIOTECA DE TREINOS
// ============================================================================

model TrainingLibrary {
  id                  String    @id @default(cuid())
  educatorId          String
  educator            Educator  @relation(fields: [educatorId], references: [id], onDelete: Cascade)
  
  name                String
  description         String?
  sessionType         SessionType
  durationMinutes     Int
  intensityPercentage Float
  instructions        String?
  
  isTemplate          Boolean   @default(true)
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([educatorId])
}

// ============================================================================
// INTEGRAÇÕES
// ============================================================================

model Integration {
  id                  String    @id @default(cuid())
  athleteId           String
  athlete             Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  
  type                IntegrationType
  accessToken         String?   // Criptografado
  refreshToken        String?   // Criptografado
  expiresAt           DateTime?
  
  lastSync            DateTime?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([athleteId, type])
  @@index([athleteId])
}

enum IntegrationType {
  garmin
  strava
  apple_health
  dieta_ia
}

// ============================================================================
// PAGAMENTOS
// ============================================================================

model Subscription {
  id                String    @id @default(cuid())
  educatorId        String    @unique
  educator          Educator  @relation(fields: [educatorId], references: [id], onDelete: Cascade)
  
  plan              Plan
  status            String    // active, canceled, past_due
  
  stripeCustomerId  String?
  stripeSubId       String?   @unique
  
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  
  canceledAt        DateTime?
  cancelReason      String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum Plan {
  free
  pro
  enterprise
}

model Payment {
  id              String    @id @default(cuid())
  educatorId      String
  
  stripeId        String    @unique
  amount          Float
  currency        String    // BRL
  status          String    // pending, succeeded, failed
  
  createdAt       DateTime  @default(now())

  @@index([educatorId])
}

// ============================================================================
// NOTIFICAÇÕES
// ============================================================================

model Notification {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            NotificationType
  title           String
  message         String
  data            Json?
  
  emailSent       Boolean   @default(false)
  smsSent         Boolean   @default(false)
  whatsappSent    Boolean   @default(false)
  
  emailError      String?
  smsError        String?
  whatsappError   String?
  
  createdAt       DateTime  @default(now())
  sentAt          DateTime?

  @@index([userId])
}

enum NotificationType {
  new_athlete
  training_completed
  training_missed
  payment_received
  plan_expiring
  new_training
  training_reminder
  educator_feedback
  progress_achieved
}

model NotificationPreferences {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  emailEnabled    Boolean   @default(true)
  smsEnabled      Boolean   @default(true)
  whatsappEnabled Boolean   @default(true)
  
  emailFrequency  String    // immediate, daily, weekly
  smsFrequency    String    // immediate, daily
  whatsappFrequency String  // immediate, daily
  
  updatedAt       DateTime  @updatedAt
}

// ============================================================================
// PERIODIZAÇÃO MACROCICLO
// ============================================================================

// Tabela de Parâmetros Configuráveis
model TrainingParameter {
  id          String   @id @default(cuid())
  category    String   // "montagem", "metodo", "divisao_treino", "carga_microciclo", "objetivo"
  code        String   // "AS", "SER", "FB", "ADP", etc
  description String   // Descrição completa
  order       Int      // Ordem de exibição
  active      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([category, code])
  @@index([category])
}

// Matriz de Periodização
model PeriodizationMatrix {
  id                String   @id @default(cuid())
  planId            String   @unique
  plan              TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  totalMesocycles   Int      // Ex: 5
  weeksPerMesocycle Int      // Ex: 4
  
  // Relacionamentos
  resistedStimulus  ResistedStimulus[]
  cyclicStimulus    CyclicStimulus[]
  nutrition         NutritionWeekly[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Estímulo Resistido (Treino de Força)
model ResistedStimulus {
  id                String   @id @default(cuid())
  matrixId          String
  matrix            PeriodizationMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  
  mesocycleNumber   Int      // 1, 2, 3, 4, 5
  weekNumber        Int      // 1-20 (ou quantas semanas tiver)
  
  // Carga Microciclo (ADP, ORD, CHO, REG)
  loadCycle         String?  // Referência ao TrainingParameter

  // Objetivo
  objective         String?  // Referência ao TrainingParameter
  
  // Parâmetros de Treino Resistido
  repZone           Int?     // Zona de Repetições (ex: 4, 6, 8, 10, 12, 14)
  loadPercentage    Float?   // % Carga TR (calculado automaticamente baseado em repZone)
  
  // Referência para cálculo de séries
  seriesReference   Int?     // REF - valor de referência
  
  // Séries calculadas
  seriesLowerBody   Int?     // Séries Membros Inferiores (calculado)
  seriesUpperBody   Int?     // Séries Membros Superiores
  seriesCore        Int?     // Séries Core/Estabilização
  
  // Rep Reserva (calculado automaticamente)
  repReserve        Int?     // Calculado baseado em loadCycle
  
  // Montagem (AS, A/AN, CA, CGM, MIS)
  assembly          String?  // Referência ao TrainingParameter
  
  // Método (SER, BS, TS, SS, CIR, CS, PC, PD, DS, RP, SN, FST-7)
  method            String?  // Referência ao TrainingParameter
  
  // Divisão do Treino (FB, AB, ABC, ABCD, ABCDE)
  trainingDivision  String?  // Referência ao TrainingParameter
  
  // Frequência Semanal
  weeklyFrequency   Int?     // Ex: 3, 4, 5
  
  // Observações
  observations      String?  @db.Text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([matrixId, mesocycleNumber, weekNumber])
  @@index([matrixId])
}

// Estímulo Cíclico (Corrida/Cardio)
model CyclicStimulus {
  id                   String   @id @default(cuid())
  matrixId             String
  matrix               PeriodizationMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  
  mesocycleNumber      Int
  weekNumber           Int
  
  // Volume
  totalVolumeMinutes   Float?   // Volume Geral em Minutos
  totalVolumeKm        Float?   // Volume Geral em KM
  runningVolumeKm      Float?   // Volume Corrida em KM
  
  // Número de Treinos por Zona
  countZ1              Int?     // Número de treinos Zona 1
  countZ2              Int?
  countZ3              Int?
  countZ4              Int?
  countZ5              Int?
  
  // Minutos por Zona
  minutesZ1            Float?   // Minutos na Zona 1
  minutesZ2            Float?
  minutesZ3            Float?
  minutesZ4            Float?
  minutesZ5            Float?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  @@unique([matrixId, mesocycleNumber, weekNumber])
  @@index([matrixId])
}

// Nutrição Semanal
model NutritionWeekly {
  id                String   @id @default(cuid())
  matrixId          String
  matrix            PeriodizationMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  
  mesocycleNumber   Int
  weekNumber        Int
  
  // Calorias e Macronutrientes
  dailyCalories     Float?   // Calorias diárias
  carbohydratesG    Float?   // Carboidratos em gramas
  proteinsG         Float?   // Proteínas em gramas
  lipidsG           Float?   // Lipídios em gramas
  
  // Hidratação
  hydrationLiters   Float?   // Hidratação em litros/dia
  
  // Suplementos
  supplements       String?  @db.Text
  
  // Observações
  notes             String?  @db.Text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([matrixId, mesocycleNumber, weekNumber])
  @@index([matrixId])
}

// ============================================================================
// TEMPLATES DE PERIODIZAÇÃO
// ============================================================================

model PeriodizationTemplate {
  id                String   @id @default(cuid())
  educatorId        String?  // null = template global
  
  name              String   // "Preparação para Maratona", "Base Aeróbica"
  description       String?  @db.Text
  category          String   // "marathon", "base", "peak", etc
  
  totalMesocycles   Int
  weeksPerMesocycle Int
  
  // Dados do template (JSON)
  templateData      Json     // Estrutura completa da matriz
  
  isPublic          Boolean  @default(false)
  usageCount        Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([educatorId])
  @@index([category])
}


// ============================================================================
// BIBLIOTECA DE EXERCÍCIOS
// ============================================================================

model ExerciseLibrary {
  id            String   @id @default(cuid())
  
  name          String   // Nome do exercício
  videoUrl      String?  @db.Text // Link do vídeo do YouTube
  loadType      LoadType? // H, C, E, A, P, O
  movementType  MovementType? // U, I, O
  countingType  CountingType? // I, T, R
  category      String?  // MOBILIDADE, RESISTIDO, CICLICO
  muscleGroup   String?  // Abdominal, Quadríceps, etc
  notes         String?  @db.Text
  
  // Relacionamentos
  workoutExercises WorkoutExercise[]
  studentProgress  StudentExerciseProgress[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([name])
  @@index([category])
}

enum LoadType {
  H  // Halteres
  C  // Corporal
  E  // Elásticos
  A  // Aeróbicos
  P  // P.S. (observações)
  O  // Outros
}

enum MovementType {
  U  // Unilateral
  I  // Isolado
  O  // Outros (Bilateral)
}

enum CountingType {
  I  // Isometria
  T  // por Tempo (Repetições)
  R  // Repetições
}

// ============================================================================
// PROGRESSO DO ALUNO POR EXERCÍCIO
// ============================================================================

model StudentExerciseProgress {
  id          String   @id @default(cuid())
  athleteId   String
  athlete     Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    ExerciseLibrary @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  
  lastLoad    Float?   // Carga anterior (última executada)
  maxLoad     Float?   // Carga máxima já levantada
  
  lastUpdated DateTime @default(now())
  
  @@unique([athleteId, exerciseId])
  @@index([athleteId])
  @@index([exerciseId])
}

// ============================================================================
// MONTAGEM DE TREINOS
// ============================================================================

model WorkoutTemplate {
  id                    String   @id @default(cuid())
  planId                String
  plan                  TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  mesocycleNumber       Int      // Meso (compartilhado entre cíclico e resistido)
  weekNumber            Int      // Micro (compartilhado entre cíclico e resistido)
  weekStartDate         DateTime
  
  // Dados do Cíclico
  cyclicFrequency       Int?     // Frequência semanal de treinos cíclicos
  totalVolumeMin        Int?
  totalVolumeKm         Float?
  
  // Dados do Resistido
  resistanceFrequency   Int?     // Frequência semanal de treinos de força
  loadPercentage        Float?
  repZone               Int?
  repReserve            Int?
  trainingMethod        String?
  trainingDivision      String?
  
  // Observações
  studentGoal           String?  @db.Text
  coachGoal             String?  @db.Text
  observation1          String?  @db.Text
  observation2          String?  @db.Text
  
  // Status de Liberação
  released              Boolean  @default(false) // Se true, o treino está disponível para o atleta
  releasedAt            DateTime? // Data/hora em que foi liberado
  
  // Relacionamentos
  workoutDays           WorkoutDay[]
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([planId, mesocycleNumber, weekNumber])
  @@index([planId])
  @@index([planId, mesocycleNumber, weekNumber])
}

model WorkoutDay {
  id                    String   @id @default(cuid())
  templateId            String
  template              WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dayOfWeek             Int      // 1=Segunda, 7=Domingo
  workoutDate           DateTime
  
  // Planejamento do Dia - Geral
  sessionDurationMin    Int?     // Tempo total da sessão
  cyclicTimeMin         Int?     // Tempo de treino cíclico
  resistanceTimeMin     Int?     // Tempo de treino resistido
  
  // Planejamento do Dia - Cíclico
  stimulusDurationMin   Int?     // Tempo do estímulo
  location              String?  // Esteira, Bicicleta, Pista, Corrida
  method                String?  // CEXT, CINT, IEXT, IINT
  
  // Intensidades
  intensity1            Float?   // Intensidade 1 (porcentagem)
  intensity2            Float?   // Intensidade 2 (porcentagem)
  numSessions           Int?     // Número de sessões
  numSets               Int?     // Número de séries
  sessionTime           Int?     // Tempo intenso (segundos)
  restTime              Int?     // Tempo repouso (segundos)
  vo2maxIntervalPct     Float?   // %VO2Máx intervalo
  iextIintTime          Float?   // Tempo IEXT IINT
  vo2maxPct             Float?   // %VO2Máx
  targetHrMin           Float?   // FC alvo mínima (bpm)
  targetHrMax           Float?   // FC alvo máxima (bpm)
  targetSpeedMin        Float?   // Velocidade mínima (km/h)
  targetSpeedMax        Float?   // Velocidade máxima (km/h)
  paceMin               Float?   // Pace mínimo (min/km)
  paceMax               Float?   // Pace máximo (min/km)
  
  // Detalhamento e Complemento
  detailNotes           String?  @db.Text
  complementNotes       String?  @db.Text
  
  // Orientações Gerais
  generalGuidelines     String?  @db.Text
  
  // PSR (Percepção Subjetiva de Recuperação)
  psrQuestion           String?  @default("Hoje recuperado você está se sentindo (PSR)?")
  psrResponse           Int?     // Resposta do aluno (1-10)
  
  // Relacionamentos
  exercises             WorkoutExercise[]
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([templateId, dayOfWeek])
  @@index([templateId])
  @@index([workoutDate])
}

model WorkoutExercise {
  id              String   @id @default(cuid())
  workoutDayId    String
  workoutDay      WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exerciseId      String
  exercise        ExerciseLibrary @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  
  // Seção do Treino
  section         String   // MOBILIDADE, AQUECIMENTO, ATIVACAO, TECNICO, SESSAO
  exerciseOrder   Int      // Ordem dentro da seção
  
  // Parâmetros do Exercício
  system          String?  // BI-SET, TRI-SET, CIRCUITO
  sets            Int?
  reps            Int?
  intervalSec     Int?     // Intervalo entre séries
  cParam          Int?     // Parâmetro C (específico do treino)
  eParam          Int?     // Parâmetro E (específico do treino)
  load            Float?   // Carga sugerida
  
  // Observações
  exerciseNotes   String?  @db.Text
  
  // Relacionamentos
  executions      WorkoutExecution[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([workoutDayId])
  @@index([workoutDayId, section, exerciseOrder])
}

// ============================================================================
// EXECUÇÃO REAL DO TREINO
// ============================================================================

model WorkoutExecution {
  id                  String   @id @default(cuid())
  workoutExerciseId   String
  workoutExercise     WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  athleteId           String
  athlete             Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  executionDate       DateTime
  
  // Dados Executados
  setsCompleted       Int?
  repsCompleted       Int?
  loadUsed            Float?
  
  // Feedback
  difficultyRating    Int?     // 1-10
  repsInReserve       Int?     // Repetições em reserva
  notes               String?  @db.Text
  
  createdAt           DateTime @default(now())
  
  @@index([workoutExerciseId])
  @@index([athleteId])
  @@index([executionDate])
}
