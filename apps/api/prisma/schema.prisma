  @@unique([alunoId, exerciseId])
  @@index([alunoId])
  @@index([exerciseId])
}

// ============================================================================
// MONTAGEM DE TREINOS
// ============================================================================

model WorkoutTemplate {
  id              String       @id @default(cuid())
  planId          String
  plan            TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  mesocycleNumber Int // Meso (compartilhado entre cÃ­clico e resistido)
  weekNumber      Int // Micro (compartilhado entre cÃ­clico e resistido)
  weekStartDate   DateTime

  // Dados do CÃ­clico
  cyclicFrequency Int? // FrequÃªncia semanal de treinos cÃ­clicos
  totalVolumeMin  Int?
  totalVolumeKm   Float?

  // Dados do Resistido
  resistanceFrequency Int? // FrequÃªncia semanal de treinos de forÃ§a
  loadPercentage      Float?
  repZone             Int?
  repReserve          Int?
  trainingMethod      String?
  trainingDivision    String?

  // ObservaÃ§Ãµes
  alunoGoal    String? @db.Text
  coachGoal    String? @db.Text
  observation1 String? @db.Text
  observation2 String? @db.Text

  // Status de LiberaÃ§Ã£o
  released   Boolean   @default(false) // Se true, o treino estÃ¡ disponÃ­vel para o aluno
  releasedAt DateTime? // Data/hora em que foi liberado

  // Relacionamentos
  workoutDays WorkoutDay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, mesocycleNumber, weekNumber])
  @@index([planId])
  @@index([planId, mesocycleNumber, weekNumber])
}

model WorkoutDay {
  id          String           @id @default(cuid())
  templateId  String
  template    WorkoutTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  dayOfWeek   Int // 1=Segunda, 7=Domingo
  workoutDate DateTime
  status      WorkoutDayStatus @default(planned)
  startedAt   DateTime?
  finishedAt  DateTime?

  // Planejamento do Dia - Geral
  sessionDurationMin Int? // Tempo total da sessÃ£o
  cyclicTimeMin      Int? // Tempo de treino cÃ­clico
  resistanceTimeMin  Int? // Tempo de treino resistido

  // Planejamento do Dia - CÃ­clico
  stimulusDurationMin Int? // Tempo do estÃ­mulo
  location            String? // Esteira, Bicicleta, Pista, Corrida
  method              String? // CEXT, CINT, IEXT, IINT

  // Intensidades
  intensity1        Float? // Intensidade 1 (porcentagem)
  intensity2        Float? // Intensidade 2 (porcentagem)
  numSessions       Int? // NÃºmero de sessÃµes
  numSets           Int? // NÃºmero de sÃ©ries
  sessionTime       Int? // Tempo intenso (segundos)
  restTime          Int? // Tempo repouso (segundos)
  vo2maxIntervalPct Float? // %VO2MÃ¡x intervalo
  iextIintTime      Float? // Tempo IEXT IINT
  vo2maxPct         Float? // %VO2MÃ¡x
  targetHrMin       String? @db.Text // FC alvo (bpm)
  targetHrMax       String? @db.Text // FC alvo mÃ¡ximo (bpm)
  targetSpeedMin    String? @db.Text // Velocidade (km/h)
  targetSpeedMax    String? @db.Text // Velocidade mÃ¡xima (km/h)
  paceMin           Float? // Pace mÃ­nimo (min/km)
  paceMax           Float? // Pace mÃ¡ximo (min/km)

  // Detalhamento e Complemento
  detailNotes     String? @db.Text
  complementNotes String? @db.Text

  // OrientaÃ§Ãµes Gerais
  generalGuidelines String? @db.Text

  // PSR (PercepÃ§Ã£o Subjetiva de RecuperaÃ§Ã£o)
  psrQuestion String? @default("Hoje recuperado vocÃª estÃ¡ se sentindo (PSR)?")
  psrResponse Int? // Resposta do aluno (1-10)
  pseResponse Int? // Percep????o de esfor??o ap??s o treino (1-10)

  // Relacionamentos
  exercises WorkoutExercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateId, dayOfWeek])
  @@index([templateId])
  @@index([workoutDate])
}

enum WorkoutDayStatus {
  planned
  in_progress
  completed
}

model WorkoutExercise {
  id           String          @id @default(cuid())
  workoutDayId String
  workoutDay   WorkoutDay      @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exerciseId   String
  exercise     ExerciseLibrary @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  // SeÃ§Ã£o do Treino
  section       String // MOBILIDADE, AQUECIMENTO, ATIVACAO, TECNICO, SESSAO
  exerciseOrder Int // Ordem dentro da seÃ§Ã£o

  // ParÃ¢metros do ExercÃ­cio
  system      String? // BI-SET, TRI-SET, CIRCUITO
  sets        Int?
  reps        Int?
  intervalSec Int? // Intervalo entre sÃ©ries
  cParam      Int? // ParÃ¢metro C (especÃ­fico do treino)
  eParam      Int? // ParÃ¢metro E (especÃ­fico do treino)
  load        Float? // Carga sugerida

  // ObservaÃ§Ãµes
  exerciseNotes String? @db.Text

  // Relacionamentos
  executions WorkoutExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workoutDayId])
  @@index([workoutDayId, section, exerciseOrder])
}

// ============================================================================
// EXECUÃ‡ÃƒO REAL DO TREINO
// ============================================================================

model WorkoutExecution {
  id                String          @id @default(cuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  alunoId           String
