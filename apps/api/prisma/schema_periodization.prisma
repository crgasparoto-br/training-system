// ============================================================================
// PERIODIZAГѓвЂЎГѓЖ’O MACROCICLO
// ============================================================================

// Tabela de ParГѓВўmetros ConfigurГѓВЎveis
model TrainingParameter {
  id          String   @id @default(cuid())
  category    String   // "montagem", "metodo", "divisao_treino", "carga_microciclo", "objetivo"
  code        String   // "AS", "SER", "FB", "ADP", etc
  description String   // DescriГѓВ§ГѓВЈo completa
  order       Int      // Ordem de exibiГѓВ§ГѓВЈo
  active      Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([category, code])
  @@index([category])
}

// Matriz de PeriodizaГѓВ§ГѓВЈo
model PeriodizationMatrix {
  id                String   @id @default(cuid())
  planId            String   @unique
  plan              TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  totalMesocycles   Int      // Ex: 5
  weeksPerMesocycle Int      // Ex: 4
  
  // Relacionamentos
  resistedStimulus  ResistedStimulus[]
  cyclicStimulus    CyclicStimulus[]
  nutrition         NutritionWeekly[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// EstГѓВ­mulo Resistido (Treino de ForГѓВ§a)
model ResistedStimulus {
  id                String   @id @default(cuid())
  matrixId          String
  matrix            PeriodizationMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  
  mesocycleNumber   Int      // 1, 2, 3, 4, 5
  weekNumber        Int      // 1-20 (ou quantas semanas tiver)
  
  // Carga Microciclo (ADP, ORD, CHO, REG)
  loadCycle         String   // ReferГѓВЄncia ao TrainingParameter

  // Objetivo
  objective         String?  // ReferГѓВЄncia ao TrainingParameter
  
  // ParГѓВўmetros de Treino Resistido
  repZone           Int?     // Zona de RepetiГѓВ§ГѓВµes (ex: 4, 6, 8, 10, 12, 14)
  loadPercentage    Float?   // % Carga TR (calculado automaticamente baseado em repZone)
  
  // ReferГѓВЄncia para cГѓВЎlculo de sГѓВ©ries
  seriesReference   Int?     // REF - valor de referГѓВЄncia
  
  // SГѓВ©ries calculadas
  seriesLowerBody   Int?     // SГѓВ©ries Membros Inferiores (calculado)
  seriesUpperBody   Int?     // SГѓВ©ries Membros Superiores
  seriesCore        Int?     // SГѓВ©ries Core/EstabilizaГѓВ§ГѓВЈo
  
  // Rep Reserva (calculado automaticamente)
  repReserve        Int?     // Calculado baseado em loadCycle
  
  // Montagem (AS, A/AN, CA, CGM, MIS)
  assembly          String?  // ReferГѓВЄncia ao TrainingParameter
  
  // MГѓВ©todo (SER, BS, TS, SS, CIR, CS, PC, PD, DS, RP, SN, FST-7)
  method            String?  // ReferГѓВЄncia ao TrainingParameter
  
  // DivisГѓВЈo do Treino (FB, AB, ABC, ABCD, ABCDE)
  trainingDivision  String?  // ReferГѓВЄncia ao TrainingParameter
  
  // FrequГѓВЄncia Semanal
  weeklyFrequency   Int?     // Ex: 3, 4, 5
  
  // ObservaГѓВ§ГѓВµes
  observations      String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([matrixId, mesocycleNumber, weekNumber])
  @@index([matrixId])
}

// EstГѓВ­mulo CГѓВ­clico (Corrida/Cardio)
model CyclicStimulus {
  id                   String   @id @default(cuid())
  matrixId             String
  matrix               PeriodizationMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  
  mesocycleNumber      Int
  weekNumber           Int
  
  // Volume
  totalVolumeMinutes   Float?   // Volume Geral em Minutos
  totalVolumeKm        Float?   // Volume Geral em KM
  runningVolumeKm      Float?   // Volume Corrida em KM
  
  // NГѓВєmero de Treinos por Zona
  countZ1              Int?     // NГѓВєmero de treinos Zona 1
  countZ2              Int?
  countZ3              Int?
  countZ4              Int?
  countZ5              Int?
  
  // Minutos por Zona
  minutesZ1            Float?   // Minutos na Zona 1
  minutesZ2            Float?
  minutesZ3            Float?
  minutesZ4            Float?
  minutesZ5            Float?
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  @@unique([matrixId, mesocycleNumber, weekNumber])
  @@index([matrixId])
}

// NutriГѓВ§ГѓВЈo Semanal
model NutritionWeekly {
  id                String   @id @default(cuid())
  matrixId          String
  matrix            PeriodizationMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  
  mesocycleNumber   Int
  weekNumber        Int
  
  // Calorias e Macronutrientes
  dailyCalories     Float?   // Calorias diГѓВЎrias
  carbohydratesG    Float?   // Carboidratos em gramas
  proteinsG         Float?   // ProteГѓВ­nas em gramas
  lipidsG           Float?   // LipГѓВ­dios em gramas
  
  // HidrataГѓВ§ГѓВЈo
  hydrationLiters   Float?   // HidrataГѓВ§ГѓВЈo em litros/dia
  
  // Suplementos
  supplements       String?  // Texto livre
  
  // ObservaГѓВ§ГѓВµes
  notes             String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([matrixId, mesocycleNumber, weekNumber])
  @@index([matrixId])
}

// ============================================================================
// TEMPLATES DE PERIODIZAГѓвЂЎГѓЖ’O
// ============================================================================

model PeriodizationTemplate {
  id                String   @id @default(cuid())
  professorId        String?  // null = template global
  
  name              String   // "PreparaГѓВ§ГѓВЈo para Maratona", "Base AerГѓВіbica"
  description       String?
  category          String   // "marathon", "base", "peak", etc
  
  totalMesocycles   Int
  weeksPerMesocycle Int
  
  // Dados do template (JSON)
  templateData      Json     // Estrutura completa da matriz
  
  isPublic          Boolean  @default(false)
  usageCount        Int      @default(0)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([professorId])
  @@index([category])
}

