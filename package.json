{
  "name": "training_system",
  "version": "0.1.0",
  "description": "Sistema SaaS de gestão de treinos de corrida",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r run dev",
    "dev:api": "pnpm --filter @corrida/api dev",
    "dev:web": "pnpm --filter @corrida/web dev -- --host 0.0.0.0",
    "dev:local": "pnpm --parallel --filter @corrida/api --filter @corrida/web run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "type-check": "pnpm -r run type-check"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
